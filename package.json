{
  "name": "code-info",
  "displayName": "code-info",
  "description": "查看当前项目代码详情",
  "version": "0.0.3",
  "icon": "resources/icon.png",
  "publisher": "tingfeng",
  "repository": {
    "type": "git",
    "url": "https://github.com/lisentowind/vscode-code-info.git"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "code stats",
    "lines of code",
    "dashboard",
    "git analytics"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeInfo.showStats",
        "title": "Analyze Workspace",
        "category": "Code Info",
        "shortTitle": "Analyze"
      },
      {
        "command": "codeInfo.selectAnalysisDirectories",
        "title": "Select Analysis Directories",
        "category": "Code Info",
        "shortTitle": "Scope"
      },
      {
        "command": "codeInfo.openPanel",
        "title": "Dashboard",
        "category": "Code Info",
        "shortTitle": "Dashboard"
      },
      {
        "command": "codeInfo.refreshStats",
        "title": "Refresh",
        "category": "Code Info",
        "shortTitle": "Refresh"
      },
      {
        "command": "codeInfo.refreshTodayStats",
        "title": "Refresh Today Stats",
        "category": "Code Info",
        "shortTitle": "Today"
      },
      {
        "command": "codeInfo.export",
        "title": "Export",
        "category": "Code Info",
        "shortTitle": "Export"
      },
      {
        "command": "codeInfo.exportJson",
        "title": "Export JSON",
        "category": "Code Info",
        "shortTitle": "JSON"
      },
      {
        "command": "codeInfo.exportCsv",
        "title": "Export CSV",
        "category": "Code Info",
        "shortTitle": "CSV"
      }
    ],
    "configuration": {
      "title": "Code Info",
      "properties": {
        "codeInfo.analysis.directories": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "scope": "window",
          "description": "限制分析范围到指定目录。空数组表示分析整个工作区。单根工作区示例：['src','packages/app']。多根工作区可用 'workspaceFolderName:dir' 仅分析某个根，例如：['client:src','server:src']。"
        },
        "codeInfo.analysis.moduleDepth": {
          "type": "number",
          "default": 1,
          "minimum": 1,
          "maximum": 4,
          "scope": "window",
          "description": "模块统计按几级目录聚合。1 表示按顶层目录统计，2 表示按两级目录统计。"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codeInfo",
          "title": "Code Info",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "codeInfo": [
        {
          "id": "codeInfo.sidebar",
          "name": "Overview",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "codeInfo.openPanel",
          "when": "view == codeInfo.sidebar",
          "group": "navigation"
        },
        {
          "command": "codeInfo.selectAnalysisDirectories",
          "when": "view == codeInfo.sidebar",
          "group": "navigation@0"
        },
        {
          "command": "codeInfo.refreshStats",
          "when": "view == codeInfo.sidebar",
          "group": "navigation@1"
        },
        {
          "command": "codeInfo.refreshTodayStats",
          "when": "view == codeInfo.sidebar",
          "group": "navigation@1.5"
        },
        {
          "command": "codeInfo.export",
          "when": "view == codeInfo.sidebar",
          "group": "navigation@2"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}