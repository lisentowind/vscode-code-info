{
  "name": "code-info",
  "displayName": "code-info",
  "description": "查看当前项目代码详情",
  "version": "0.0.8",
  "icon": "resources/icon.png",
  "publisher": "tingfeng",
  "repository": {
    "type": "git",
    "url": "https://github.com/lisentowind/vscode-code-info.git"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "code stats",
    "lines of code",
    "dashboard",
    "git analytics"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeInfo.showStats",
        "title": "分析工作区",
        "category": "代码信息",
        "shortTitle": "分析"
      },
      {
        "command": "codeInfo.selectAnalysisDirectories",
        "title": "选择分析目录",
        "category": "代码信息",
        "shortTitle": "目录"
      },
      {
        "command": "codeInfo.openPanel",
        "title": "打开看板",
        "category": "代码信息",
        "shortTitle": "看板"
      },
      {
        "command": "codeInfo.refreshStats",
        "title": "刷新统计",
        "category": "代码信息",
        "shortTitle": "刷新"
      },
      {
        "command": "codeInfo.refreshTodayStats",
        "title": "刷新今日统计",
        "category": "代码信息",
        "shortTitle": "今日"
      },
      {
        "command": "codeInfo.export",
        "title": "导出",
        "category": "代码信息",
        "shortTitle": "导出"
      },
      {
        "command": "codeInfo.exportJson",
        "title": "导出 JSON",
        "category": "代码信息",
        "shortTitle": "JSON"
      },
      {
        "command": "codeInfo.exportCsv",
        "title": "导出 CSV",
        "category": "代码信息",
        "shortTitle": "CSV"
      }
    ],
    "configuration": {
      "title": "代码信息",
      "properties": {
        "codeInfo.analysis.directories": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "scope": "window",
          "description": "限制分析范围到指定目录。空数组表示分析整个工作区。单根工作区示例：['src','packages/app']。多根工作区可用 'workspaceFolderName:dir' 仅分析某个根，例如：['client:src','server:src']。"
        },
        "codeInfo.analysis.moduleDepth": {
          "type": "number",
          "default": 1,
          "minimum": 1,
          "maximum": 4,
          "scope": "window",
          "description": "模块统计按几级目录聚合。1 表示按顶层目录统计，2 表示按两级目录统计。"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codeInfo",
          "title": "代码信息",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "codeInfo": [
        {
          "id": "codeInfo.sidebar",
          "name": "概览",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "codeInfo.openPanel",
          "when": "view == codeInfo.sidebar",
          "group": "navigation"
        },
        {
          "command": "codeInfo.selectAnalysisDirectories",
          "when": "view == codeInfo.sidebar",
          "group": "navigation@0"
        },
        {
          "command": "codeInfo.refreshStats",
          "when": "view == codeInfo.sidebar",
          "group": "navigation@1"
        },
        {
          "command": "codeInfo.refreshTodayStats",
          "when": "view == codeInfo.sidebar",
          "group": "navigation@1.5"
        },
        {
          "command": "codeInfo.export",
          "when": "view == codeInfo.sidebar",
          "group": "navigation@2"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}